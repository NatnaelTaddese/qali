# Backend / Convex environment (validated by @qali/env/server)

# Web app URL used for auth trusted origins
SITE_URL=http://localhost:3001

# Convex site URL (ends in .site) — the auth baseURL
CONVEX_SITE_URL=https://example.convex.site

# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=dev:your-deployment
CONVEX_URL=https://example.convex.cloud

# Google OAuth client (from Google Cloud Console). Required for social sign-in.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Set in the Convex deployment (not read locally) via:
#   npx convex env set BETTER_AUTH_SECRET=$(openssl rand -base64 32)
#   npx convex env set SITE_URL http://localhost:3001
#   npx convex env set CONVEX_SITE_URL https://<your-deployment>.convex.site
#   npx convex env set GOOGLE_CLIENT_ID <id>
#   npx convex env set GOOGLE_CLIENT_SECRET <secret>
